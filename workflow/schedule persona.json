      "id": "9eb7bbff-5662-42d3-8b99-03f695408b88",
      "name": "Search news"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const input = $input.item.json;\nconst articles = Array.isArray(input.articles) ? input.articles : [];\nreturn {\n  json: {\n    articles: articles.map(a => ({\n      title: a.title || '',\n      description: a.description || '',\n      url: a.url || '',\n      source: a.source?.name || ''\n    }))\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1424,
        416
      ],
      "id": "81d6572a-ec5a-4b9c-8a0d-ce9865ec9c6d",
      "name": "Simplify articles"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Preferences:\n{{ JSON.stringify($('Prepare each user').item.json.preferences) }}\n\nArticles:\n{{ JSON.stringify($json.articles) }}\n\nWrite a personalized newsletter. Return ONLY valid JSON:\n{\n  \"subject\": \"\",\n  \"body\": \"\",\n  \"articles\": [{\"title\": \"\", \"summary\": \"\", \"url\": \"\"}]\n}\n\nRules:\n- Use the tone and topics from preferences.\n- Respect the length: short or detailed.\n- Select at most 5 articles.",
        "options": {
          "systemMessage": "You are a newsletter editor. Return only valid JSON, no markdown."
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        1664,
        416
      ],
      "id": "64f34749-11fa-46db-9d4c-2b82b8999651",
      "name": "Newsletter writer"
