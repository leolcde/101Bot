      "id": "21d5149e-b429-4fed-818a-6655a0fba766",
      "name": "Every minute"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  u.id AS user_id,\n  u.email,\n  u.username,\n  pref.topics,\n  pref.frequency,\n  pref.send_day,\n  pref.send_day_of_month,\n  pref.send_time,\n  pref.tone,\n  pref.length,\n  pref.format,\n  pref.max_articles\nFROM user_preferences pref\nJOIN users u ON u.id = pref.user_id\nWHERE pref.is_subscribed = true\n  AND pref.topics != '{}'\n  AND (\n    (pref.frequency = 'daily'\n      AND TO_CHAR(NOW(), 'HH24:MI') = TO_CHAR(pref.send_time, 'HH24:MI'))\n    OR\n    (pref.frequency = 'weekly'\n      AND LOWER(TO_CHAR(NOW(), 'day')) LIKE pref.send_day || '%'\n      AND TO_CHAR(NOW(), 'HH24:MI') = TO_CHAR(pref.send_time, 'HH24:MI'))\n    OR\n    (pref.frequency = 'monthly'\n      AND EXTRACT(DAY FROM NOW()) = pref.send_day_of_month\n      AND TO_CHAR(NOW(), 'HH24:MI') = TO_CHAR(pref.send_time, 'HH24:MI'))\n  );",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        464,
        432
      ],
      "id": "4f0fe8f9-ae3a-4cc9-b64a-8134aea9d141",
      "name": "Get users to notify",
      "credentials": {
        "postgres": {
          "id": "32OWvi1TR83JGx3A",
          "name": "Postgres account 3"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 3
          },
          "conditions": [
            {
              "id": "has-users",
              "leftValue": "={{ $input.all().length }}",
              "rightValue": 0,
              "operator": {
                "type": "number",
                "operation": "gt"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
        704,
        432
      ],
      "id": "1d0b0596-124c-417c-9ec9-3882ae5d3104",
      "name": "If users to notify"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const input = $input.item.json;\nconst topics = Array.isArray(input.topics) ? input.topics.filter(t => typeof t === 'string' && t.trim()) : [];\nconst maxArticles = Number(input.max_articles) > 0 ? Number(input.max_articles) : 5;\n\nreturn {\n  json: {\n    user_id: input.user_id,\n    email: input.email || '',\n    username: input.username || '',\n    newsletterQuery: topics.length > 0 ? topics.join(' OR ') : 'latest news',\n    maxArticles,\n    preferences: {\n      topics,\n      tone: input.tone || 'neutral',\n      length: input.length || 'short',\n      format: input.format || 'personal_news',\n      max_articles: maxArticles\n    }\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        944,
        416
      ],
      "id": "5a508140-fd4d-48ce-a758-37b0b1b32761",
      "name": "Prepare each user"
    },
    {
      "parameters": {
        "url": "https://newsapi.org/v2/everything",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "q",
              "value": "={{ $json.newsletterQuery }}"
            },
            {
