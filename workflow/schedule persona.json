        624
      ],
      "id": "2b9f3e63-93fe-43d5-ba28-d5a97f9c9e72",
      "name": "Ollama Chat Model",
      "credentials": {
        "ollamaApi": {
          "id": "F6KLgcRf709Le3Oe",
          "name": "Ollama account 3"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const input = $input.item.json;\nconst userData = $('Prepare each user').item.json;\n\nlet parsed;\ntry {\n  parsed = JSON.parse(input.output || '{}');\n} catch {\n  parsed = { subject: 'Your 101Bot newsletter', body: String(input.output || ''), articles: [] };\n}\n\nconst articles = Array.isArray(parsed.articles) ? parsed.articles.slice(0, 5) : [];\n\nreturn {\n  json: {\n    subject: parsed.subject || 'Your 101Bot newsletter',\n    body: parsed.body || '',\n    articles,\n    email: userData.email,\n    username: userData.username\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1984,
        416
      ],
      "id": "f82f2a79-a409-4abe-83ac-da164df5a5ab",
      "name": "Normalize output"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const input = $input.item.json;\n\nconst articlesHtml = (Array.isArray(input.articles) ? input.articles : []).map(a => `\n  <div style=\"margin-bottom: 24px; padding: 16px; border-left: 4px solid #4F46E5; background: #f9f9f9; border-radius: 4px;\">\n    <h3 style=\"margin: 0 0 8px 0; font-size: 16px;\">\n      <a href=\"${a.url}\" style=\"color: #4F46E5; text-decoration: none;\">${a.title}</a>\n    </h3>\n    <p style=\"margin: 0; color: #555; font-size: 14px; line-height: 1.5;\">${a.summary}</p>\n    <a href=\"${a.url}\" style=\"display: inline-block; margin-top: 8px; font-size: 12px; color: #888;\">Read more →</a>\n  </div>\n`).join('');\n\nconst html = `<!DOCTYPE html>\n<html>\n<body style=\"font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 24px; color: #333;\">\n  <div style=\"background: #4F46E5; padding: 24px; border-radius: 8px; margin-bottom: 32px;\">\n    <h1 style=\"color: white; margin: 0; font-size: 22px;\">📰 101Bot Newsletter</h1>\n    <p style=\"color: #c7d2fe; margin: 8px 0 0 0; font-size: 14px;\">${input.subject}</p>\n  </div>\n  <p style=\"font-size: 15px; line-height: 1.6; margin-bottom: 28px;\">${input.body}</p>\n  ${articlesHtml}\n  <hr style=\"border: none; border-top: 1px solid #eee; margin: 32px 0;\">\n  <p style=\"color: #aaa; font-size: 12px; text-align: center;\">Sent by 101Bot for ${input.username}</p>\n</body>\n</html>`;\n\nreturn { json: { subject: input.subject, html, email: input.email, username: input.username, body: input.body, articles: input.articles } };"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
